// 3단계: Push 후 sample/values.yaml 의 해당 컴포넌트 tag 갱신 → Git push
// Jenkins Credentials: dockerhub, github-push (Username+Password: GitHub PAT 권장, Username은 깃허브 ID 또는 x-access-token)
// GIT_REPO_SLUG 는 실제 org/repo 로 맞출 것
pipeline {
  agent {
    kubernetes {
      yaml """
        spec:
          volumes:
            - name: dind-graph
              emptyDir: {}
          containers:
            - name: docker
              image: docker:27-cli
              command: ['cat']
              tty: true
              env:
                - name: DOCKER_HOST
                  value: tcp://127.0.0.1:2375
            - name: dind
              image: docker:27-dind
              args:
                - --storage-driver=vfs
              securityContext:
                privileged: true
              env:
                - name: DOCKER_TLS_CERTDIR
                  value: ""
              volumeMounts:
                - name: dind-graph
                  mountPath: /var/lib/docker
      """
    }
  }

  environment {
    IMAGE_REPO = 'dannielkil/sample-backend1'
    CONTEXT_DIR = 'sample/sources/backend1'
    DOCKERHUB_CREDENTIALS = 'dockerhub'
    GIT_PUSH_CREDENTIALS = 'github-push'
    GIT_REPO_SLUG = 'dannykil/kubernetes'
  }

  stages {
    stage('Prep') {
      steps {
        script {
          env.GIT_SHORT = sh(returnStdout: true, script: 'git rev-parse --short=7 HEAD').trim()
        }
      }
    }

    stage('Build') {
      steps {
        container('docker') {
          sh """
            set -e
            echo "Waiting for Docker daemon..."
            for i in \$(seq 1 120); do
              if docker info >/dev/null 2>&1; then echo "Docker is up."; break; fi
              if [ "\$i" -eq 120 ]; then echo "Timed out waiting for Docker"; exit 1; fi
              sleep 1
            done
            docker info
            docker build -t ${IMAGE_REPO}:${env.GIT_SHORT} ${CONTEXT_DIR}
            docker tag ${IMAGE_REPO}:${env.GIT_SHORT} ${IMAGE_REPO}:latest
          """
        }
      }
    }

    stage('Push') {
      steps {
        container('docker') {
          withCredentials([usernamePassword(credentialsId: "${DOCKERHUB_CREDENTIALS}", usernameVariable: 'DH_USER', passwordVariable: 'DH_PASS')]) {
            sh """
              echo "\$DH_PASS" | docker login -u "\$DH_USER" --password-stdin
              docker push ${IMAGE_REPO}:${env.GIT_SHORT}
              docker push ${IMAGE_REPO}:latest
            """
          }
        }
      }
    }

    stage('Prepare GitOps branch') {
      steps {
        sh """
          set -e
          git fetch origin
          git checkout -B main origin/main
        """
      }
    }

    stage('Patch values.yaml') {
      steps {
        container('docker') {
          sh """
            set -e
            export TAG='${env.GIT_SHORT}'
            docker pull mikefarah/yq:4
            docker run --rm -e TAG -v "\$PWD:/work" -w /work mikefarah/yq:4 \\
              eval -i '.components.backend1.image.tag = strenv(TAG)' sample/values.yaml
          """
        }
      }
    }

    stage('Push GitOps commit') {
      steps {
        withCredentials([usernamePassword(credentialsId: "${GIT_PUSH_CREDENTIALS}", usernameVariable: 'GH_USER', passwordVariable: 'GH_TOKEN')]) {
          sh """
            set -e
            git config user.email "jenkins@ci.local"
            git config user.name "Jenkins CI"
            git add sample/values.yaml
            if git diff --cached --quiet; then
              echo "No changes to sample/values.yaml"
              exit 0
            fi
            git commit -m "chore(sample): bump backend1 image to ${env.GIT_SHORT} [skip ci]"
            set +x
            git push "https://\${GH_USER}:\${GH_TOKEN}@github.com/${env.GIT_REPO_SLUG}.git" HEAD:main
            set -x
          """
        }
      }
    }
  }
}
